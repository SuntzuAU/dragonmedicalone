---
import site from '../site.config.json';
const c = site.colours;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Page Not Found - {site.siteName}</title>
  <style is:inline>
    body{margin:0;font-family:system-ui,-apple-system,sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;text-align:center;padding:24px}
    h1{font-size:64px;margin:0 0 8px}
    p{color:#475569;font-size:17px;margin:0 0 24px}
    a{display:inline-block;padding:12px 24px;border-radius:8px;font-weight:700;color:white;text-decoration:none}
  </style>
</head>
<body>
  <div>
    <h1>404</h1>
    <p>This page does not exist.</p>
    <a href="/" style={`background:${c.primary}`}>Back to {site.siteName}</a>
  </div>
</body>
</html>
