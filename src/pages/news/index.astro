---
import { getCollection } from 'astro:content';
import site from '../../site.config.json';
import manifest from '../../data/image-manifest.json';
const c = site.colours;
const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || '';
function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return '';
  return `${R2_BASE.replace(/\/$/, '')}/${entry.r2Key}`;
}
const posts = (await getCollection('news')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>News - {site.siteName}</title>
  <meta name="description" content={`Latest news and articles about Dragon Medical One, clinical speech recognition, and healthcare documentation in Australia.`} />
  <link rel="canonical" href={`${site.domain}/news`} />
  {site.googleAnalyticsId && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.googleAnalyticsId}`}></script>
    <script define:vars={{ gaId: site.googleAnalyticsId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  )}
  <style is:inline>
    body{margin:0;font-family:system-ui,-apple-system,sans-serif;color:#0f172a;line-height:1.6}
    .wrap{max-width:900px;margin:0 auto;padding:48px 24px}
    h1{font-size:36px;margin:0 0 32px;letter-spacing:-0.02em}
    .back{display:inline-block;margin-bottom:24px;font-size:14px;font-weight:600;text-decoration:none}
    .posts{display:grid;gap:24px}
    .post-card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;overflow:hidden;text-decoration:none;color:inherit;transition:box-shadow .15s}
    .post-card:hover{box-shadow:0 8px 24px rgba(0,0,0,.08)}
    .post-body{padding:24px}
    .post-body h2{font-size:20px;margin:0 0 8px}
    .post-body p{color:#475569;font-size:15px;margin:0 0 12px}
    .post-date{font-size:13px;color:#94a3b8}
    .post-img{aspect-ratio:16/5;background:#f0f9ff;overflow:hidden}
    .post-img img{width:100%;height:100%;object-fit:cover}
    .empty{color:#475569;font-size:16px;padding:40px 0}
    footer{background:#0f172a;color:#64748b;padding:28px 0;font-size:14px;margin-top:64px}
    .footer-inner{max-width:900px;margin:0 auto;padding:0 24px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px}
    .footer-links{display:flex;gap:20px}
    .footer-links a{color:#64748b;text-decoration:none}
    .footer-links a:hover{color:white}
  </style>
</head>
<body>
  <div class="wrap">
    <a class="back" href="/" style={`color:${c.primary}`}>&larr; Back to {site.siteName}</a>
    <h1>News</h1>
    {posts.length === 0 ? (
      <div class="empty">No articles yet. Check back soon for the latest on Dragon Medical One and clinical speech recognition in Australia.</div>
    ) : (
      <div class="posts">
        {posts.map((post) => (
          <a href={`/news/${post.slug}`} class="post-card">
            {post.data.heroImage && imgSrc(post.data.heroImage) && (
              <div class="post-img"><img src={imgSrc(post.data.heroImage)} alt={post.data.heroImageAlt || post.data.title} loading="lazy" decoding="async" /></div>
            )}
            <div class="post-body">
              <h2>{post.data.title}</h2>
              <p>{post.data.metaDescription}</p>
              <div class="post-date">{post.data.date}</div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
  <footer>
    <div class="footer-inner">
      <div>&copy; {year} {site.siteName}</div>
      <div class="footer-links">
        {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
      </div>
    </div>
  </footer>
</body>
</html>
