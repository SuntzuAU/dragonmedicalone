---
import site from '../site.config.json';
const c = site.colours;
const year = new Date().getFullYear();
const emr = site.emrPages.find(e => e.slug === 'dragon-medical-one-medical-director');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{emr.title} | {site.siteName}</title>
  <meta name="description" content={emr.metaDescription} />
  <link rel="canonical" href={`${site.domain}/${emr.slug}`} />
  {site.googleAnalyticsId && (<script async src={`https://www.googletagmanager.com/gtag/js?id=${site.googleAnalyticsId}`}></script><script define:vars={{ gaId: site.googleAnalyticsId }}>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config',gaId);</script>)}
  <style is:inline>
    body{margin:0;font-family:system-ui,-apple-system,sans-serif;color:#0f172a;line-height:1.7}.wrap{max-width:900px;margin:0 auto;padding:0 24px}a{color:inherit}.back{display:inline-block;margin:24px 0;font-size:14px;font-weight:600;text-decoration:none}.hero{padding:48px 0 32px}.hero h1{font-size:36px;margin:0 0 16px;letter-spacing:-0.02em}.hero p{font-size:17px;color:#334155;max-width:720px;margin:0 0 28px}.hero-btns{display:flex;gap:12px;flex-wrap:wrap}.btn{display:inline-block;padding:14px 28px;border-radius:10px;font-weight:700;font-size:16px;text-decoration:none;border:2px solid transparent}.video-outer{max-width:760px;margin:0 auto 48px}.yt-facade{position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:16px;box-shadow:0 24px 64px rgba(0,0,0,.15);cursor:pointer;background:#000}.yt-facade img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border-radius:16px}.yt-facade .yt-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:68px;height:48px;background:#ff0000;border-radius:12px;display:flex;align-items:center;justify-content:center;transition:background .15s,transform .15s}.yt-facade:hover .yt-play{background:#cc0000;transform:translate(-50%,-50%) scale(1.08)}.yt-facade .yt-play svg{width:24px;height:24px;fill:white;margin-left:4px}.yt-facade iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:0;border-radius:16px}section{padding:48px 0}.content-block{max-width:720px}.content-block h2{font-size:26px;margin:0 0 12px}.content-block p{font-size:16px;color:#334155;margin:0 0 16px}.benefits-list{list-style:none;padding:0;margin:24px 0}.benefits-list li{padding:12px 0;border-bottom:1px solid #f1f5f9;font-size:15px;color:#334155;display:flex;gap:10px;align-items:flex-start}.benefits-list li::before{content:"\2713";font-weight:700;flex-shrink:0}.formbox{background:#fff;border-radius:16px;padding:28px;max-width:480px}._form_element{margin-bottom:12px}._form_element input{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;color:#0f172a;font-size:14px;font-family:system-ui,-apple-system,sans-serif;padding:10px 12px;width:100%;box-sizing:border-box}._submit{border:none;border-radius:8px;font-weight:700;font-size:15px;padding:12px 20px;width:100%;margin-top:8px;cursor:pointer}.cta-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start}footer{background:#0f172a;color:#64748b;padding:28px 0;font-size:14px;margin-top:0}.footer-inner{max-width:900px;margin:0 auto;padding:0 24px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px}.footer-links{display:flex;gap:20px}.footer-links a{color:#64748b;text-decoration:none}.footer-links a:hover{color:white}@media(max-width:700px){.cta-grid{grid-template-columns:1fr}.hero h1{font-size:28px}}
  </style>
</head>
<body>
  <div class="wrap"><a class="back" href="/" style={`color:${c.primary}`}>&larr; Back to {site.siteName}</a></div>
  <section class="hero"><div class="wrap"><h1>{emr.heroHeading}</h1><p>{emr.heroBody}</p><div class="hero-btns"><a class="btn" href="#emr-cta" style={`background:${c.accent};color:${c.text}`}>Request Free Trial</a><a class="btn" href={site.secondaryCTA.url} style={`background:white;border-color:#cbd5e1;color:${c.primary}`}>{site.secondaryCTA.text}</a></div></div></section>
  <div class="wrap"><div class="video-outer"><div class="yt-facade" data-ytid={emr.youtubeId}><img src={`https://i.ytimg.com/vi/${emr.youtubeId}/maxresdefault.jpg`} alt={`${emr.title} video`} loading="lazy" decoding="async" /><div class="yt-play"><svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z"/></svg></div></div></div><script>document.querySelectorAll('.yt-facade').forEach(function(el){el.addEventListener('click',function(){var id=el.dataset.ytid;var iframe=document.createElement('iframe');iframe.src='https://www.youtube-nocookie.com/embed/'+id+'?autoplay=1&rel=0&modestbranding=1';iframe.allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';iframe.allowFullscreen=true;el.innerHTML='';el.appendChild(iframe);});});</script></div>
  <section><div class="wrap"><div class="content-block"><h2>How it works</h2><p>{emr.howItWorks}</p></div></div></section>
  <section style={`background:${c.neutral}`}><div class="wrap"><div class="content-block"><h2>Key benefits</h2><ul class="benefits-list">{emr.keyBenefits.map(b => <li style={`color:${c.accent}`}><span style="color:#334155">{b}</span></li>)}</ul></div></div></section>
  <section id="emr-cta" style={`background:linear-gradient(135deg, ${c.primary}, ${c.primaryLight});color:white;padding:56px 0`}><div class="wrap"><div class="cta-grid"><div><h2 style="color:white;font-size:28px;margin:0 0 12px">Try Dragon Medical One with {emr.emrName}</h2><p style="color:#94a3b8;margin:0 0 20px">Tell us about your practice and we will arrange a free trial with remote installation and personalised training.</p></div><div class="formbox"><div style="font-weight:800;font-size:18px;color:#0f172a;margin-bottom:12px">Request free trial</div><form method="POST" action="https://voicerecognition.activehosted.com/proc.php" novalidate><input type="hidden" name="u" value={site.form.hiddenU} /><input type="hidden" name="f" value={site.form.hiddenF} /><input type="hidden" name="s" /><input type="hidden" name="c" value="0" /><input type="hidden" name="m" value="0" /><input type="hidden" name="act" value="sub" /><input type="hidden" name="v" value="2" /><input type="hidden" name="or" value={site.form.hiddenOr} /><div class="_form_element"><input type="text" name="firstname" placeholder="Your Name" required /></div><div class="_form_element"><input type="text" name="email" placeholder="Your Email" required /></div><div class="_form_element"><input type="text" name="phone" placeholder="Phone" /></div><div class="_form_element"><input type="text" name="field[35]" placeholder="Practice / Organisation" /></div><button class="_submit" type="submit" style={`background:${c.accent};color:${c.text}`}>{site.form.submitText}</button></form></div></div></div></section>
  <footer><div class="footer-inner"><div>&copy; {year} {site.siteName}</div><div class="footer-links">{site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}</div></div><div style="max-width:900px;margin:12px auto 0;padding:0 24px;font-size:11px;color:#475569;line-height:1.6">Dragon and Dragon Medical One are trademarks of Microsoft Corporation. {emr.emrName} is a trademark of its respective owner.</div></footer>
</body>
</html>
