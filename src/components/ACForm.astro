---
// ActiveCampaign Form 289 - Dragon Medical One Australia
// Full embed including validation JavaScript - submits via JSONP to stay on page
// Optional prop: submitText overrides site.form.submitText (e.g. for dragon-copilot "Register Interest")
//
// IMPORTANT: Phone field uses name="field[36]" (custom field), NOT name="phone".
// Using name="phone" triggers AC's server-side phone validation which rejects any
// value that isn't in +XXXXXXXXXXXXX international format, even though phone is
// optional. Mapping to a custom field bypasses this entirely.
// field[35] = practice_organisation
// field[36] = phone_number (custom text field in AC - any format accepted)
// field[18] = comments_about_your_needs
import site from '../site.config.json';
const c = site.colours;
const formId = site.form.id;
const { submitText = site.form.submitText } = Astro.props;
---
<div class="formbox">
  <div style="font-weight:800;font-size:20px;color:#0f172a;margin-bottom:4px">Get in touch</div>
  <div style="color:#475569;font-size:15px;margin-bottom:16px">Local Australian support. Fast response.</div>

  <form method="POST" action="https://voicerecognition.activehosted.com/proc.php" id={`vra_form_${formId}`} novalidate>
    <input type="hidden" name="u" value={site.form.hiddenU} />
    <input type="hidden" name="f" value={site.form.hiddenF} />
    <input type="hidden" name="s" />
    <input type="hidden" name="c" value="0" />
    <input type="hidden" name="m" value="0" />
    <input type="hidden" name="act" value="sub" />
    <input type="hidden" name="v" value="2" />
    <input type="hidden" name="or" value={site.form.hiddenOr} />
    <div class="vra-form-content">
      <div class="vra-field">
        <input type="text" id="firstname" name="firstname" placeholder="Your Name" required autocomplete="name" />
      </div>
      <div class="vra-field">
        <input type="text" id="email" name="email" placeholder="Your Email" required autocomplete="email" />
      </div>
      <div class="vra-field">
        <!-- NOTE: name="field[36]" not name="phone" — avoids AC server-side +E.164 phone validation -->
        <input type="text" id="field36" name="field[36]" placeholder="Your Phone Number" autocomplete="off" />
      </div>
      <div class="vra-field">
        <input type="text" id="field35" name="field[35]" placeholder="Practice / Organisation" />
      </div>
      <div class="vra-field">
        <textarea id="field18" name="field[18]" placeholder="Tell us about your needs"></textarea>
      </div>
      <div class="vra-field">
        <button id={`vra_form_${formId}_submit`} class="vra-submit" type="submit" style={`background:${c.accent};color:${c.text}`}>{submitText}</button>
      </div>
    </div>
    <div class="vra-thank-you" style="display:none;"></div>
  </form>
</div>

<style is:inline>
  .formbox { background: #fff; border-radius: 16px; padding: 28px; display: flex; flex-direction: column; gap: 16px; }
  .vra-field { margin-bottom: 10px; }
  .vra-field input[type="text"],
  .vra-field textarea {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    color: #0f172a;
    font-size: 14px;
    font-family: system-ui, -apple-system, sans-serif;
    padding: 10px 12px;
    width: 100%;
    box-sizing: border-box;
  }
  .vra-field input._has_error,
  .vra-field textarea._has_error {
    border-color: #ef4444;
  }
  .vra-field textarea { resize: vertical; min-height: 80px; }
  .vra-submit {
    border: none;
    border-radius: 8px;
    font-weight: 700;
    font-size: 15px;
    padding: 12px 20px;
    width: 100%;
    margin-top: 8px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .vra-submit:hover { opacity: 0.9; }
  .vra-submit:disabled { opacity: 0.5; cursor: not-allowed; }
  .vra-error-msg {
    padding: 8px 12px;
    background: #FFDDDD;
    border-radius: 4px;
    font-size: 13px;
    color: #000;
    margin-bottom: 8px;
  }
  .vra-thank-you {
    text-align: center;
    font-size: 16px;
    font-weight: 600;
    color: #166534;
    padding: 20px;
  }
</style>

<script define:vars={{ formId }}>
  window.cfields = {"35": "practice_organisation", "36": "phone_number", "18": "comments_about_your_needs"};

  window._show_thank_you = function(id, message, trackcmp_url, email) {
    var form = document.getElementById('vra_form_' + id),
        thank_you = form.querySelector('.vra-thank-you');
    form.querySelector('.vra-form-content').style.display = 'none';
    thank_you.innerHTML = message;
    thank_you.style.display = 'block';
    const vgoAlias = typeof visitorGlobalObjectAlias === 'undefined' ? 'vgo' : visitorGlobalObjectAlias;
    var visitorObject = window[vgoAlias];
    if (email && typeof visitorObject !== 'undefined') {
      visitorObject('setEmail', email);
      visitorObject('update');
    } else if (typeof(trackcmp_url) != 'undefined' && trackcmp_url) {
      _load_script(trackcmp_url);
    }
  };

  window._show_error = function(id, message, html) {
    var form = document.getElementById('vra_form_' + id),
        err = document.createElement('div'),
        button = form.querySelector('button[type="submit"]'),
        old_error = form.querySelector('.vra-form-error');
    if (old_error) old_error.parentNode.removeChild(old_error);
    err.innerHTML = message;
    err.className = 'vra-error-msg vra-form-error';
    button.parentNode.insertBefore(err, button);
    var submitButton = form.querySelector('[id^="vra_form"][id$="_submit"]');
    submitButton.disabled = false;
  };

  window._load_script = function(url, callback, isSubmit) {
    var head = document.querySelector('head'), script = document.createElement('script'), r = false;
    var submitButton = document.querySelector('#vra_form_' + formId + '_submit');
    script.charset = 'utf-8';
    script.src = url;
    if (callback) {
      script.onload = script.onreadystatechange = function() {
        if (!r && (!this.readyState || this.readyState == 'complete')) {
          r = true; callback();
        }
      };
    }
    script.onerror = function() {
      if (isSubmit) {
        _show_error(formId, "Sorry, your submission failed. Please try again.");
        submitButton.disabled = false;
      }
    };
    head.appendChild(script);
  };

  (function() {
    if (window.location.search.indexOf('excludeform') !== -1) return false;
    var form_to_submit = document.getElementById('vra_form_' + formId);
    if (!form_to_submit) return;
    var allInputs = form_to_submit.querySelectorAll('input, select, textarea');

    var validate_field = function(elem) {
      var value = elem.value, no_error = true;
      elem.className = elem.className.replace(/ ?_has_error ?/g, '');
      if (elem.getAttribute('required') !== null) {
        if (value === undefined || value === null || value === '') {
          elem.className = elem.className + ' _has_error';
          no_error = false;
        }
      }
      if (no_error && elem.name === 'email') {
        if (!value.match(/^[\+_a-z0-9-'&=]+(\.[\+_a-z0-9-']+)*@[a-z0-9-]+(\.[a-z0-9-]+)*(\.[a-z]{2,})$/i)) {
          elem.className = elem.className + ' _has_error';
          no_error = false;
        }
      }
      // Phone (field[36]) is intentionally NOT validated - optional, any format accepted
      return no_error;
    };

    var validate_form = function(e) {
      var no_error = true;
      for (var i = 0; i < allInputs.length; i++) {
        var input = allInputs[i];
        if (input.getAttribute('required') !== null || input.name === 'email') {
          if (!validate_field(input)) no_error = false;
        }
      }
      if (!no_error && e) e.preventDefault();
      return no_error;
    };

    var _form_serialize = function(form) {
      if (!form || form.nodeName !== 'FORM') return;
      var i, q = [];
      for (i = 0; i < form.elements.length; i++) {
        if (form.elements[i].name === '') continue;
        switch (form.elements[i].nodeName) {
          case 'INPUT':
            switch (form.elements[i].type) {
              case 'text': case 'hidden': case 'password': case 'button': case 'reset': case 'submit':
                q.push(form.elements[i].name + '=' + encodeURIComponent(form.elements[i].value)); break;
              case 'checkbox': case 'radio':
                if (form.elements[i].checked) q.push(form.elements[i].name + '=' + encodeURIComponent(form.elements[i].value)); break;
            } break;
          case 'TEXTAREA':
            q.push(form.elements[i].name + '=' + encodeURIComponent(form.elements[i].value)); break;
          case 'SELECT':
            q.push(form.elements[i].name + '=' + encodeURIComponent(form.elements[i].value)); break;
        }
      }
      return q.join('&');
    };

    form_to_submit.addEventListener('submit', function(e) {
      e.preventDefault();
      if (validate_form(e)) {
        var submitButton = document.getElementById('vra_form_' + formId + '_submit');
        submitButton.disabled = true;
        var serialized = _form_serialize(form_to_submit).replace(/%0A/g, '\\n');
        var err = form_to_submit.querySelector('.vra-form-error');
        if (err) err.parentNode.removeChild(err);
        _load_script('https://voicerecognition.activehosted.com/proc.php?' + serialized + '&jsonp=true', null, true);
      }
    });
  })();
</script>
